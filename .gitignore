# ==================== Python 通用缓存/编译文件 ====================
# Python 字节码缓存
__pycache__/
*.pyc
*.pyo
*.pyd
*.whl
*.egg-info/
.eggs/

# ==================== 项目数据/模型（核心忽略项） ====================
# 数据集（自动下载/手动放的都忽略）
data/
# 模型权重
model/
# 训练输出（图片/日志）
outputs/

# ==================== 开发工具配置（按需忽略） ====================
# VS Code 配置（留着，兼容不同编辑器）
.vscode/
# PyCharm 配置（重点新增！）
.idea/
*.iml
*.ipr
*.iws
# Conda 环境（避免上传虚拟环境）
.conda/
env/
conda_env/
# 系统临时文件
.DS_Store/
Thumbs.db
*.log

# ==================== 其他可选忽略项 ====================
# Jupyter 笔记本（如果用的话）
.ipynb_checkpoints/
*.ipynb
# 缓存/临时文件夹
.cache/
.tmp/